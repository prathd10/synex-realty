# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service role key — Project Settings → API → service_role.
# Server-side / seed-script only. Bypasses RLS. Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# ImageKit — Developer Options
VITE_IMAGEKIT_PUBLIC_KEY=
VITE_IMAGEKIT_URL_ENDPOINT=

# ImageKit private key is a server-side secret for signing uploads.
# Never prefix it with VITE_ — that exposes it in the client bundle.
IMAGEKIT_PRIVATE_KEY=
